<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Time-Sensitive notifications let the morning alarm break through Focus /
	  scheduled summaries. NOTE: this does NOT override the hardware silent
	  switch — that needs the Critical Alerts entitlement, which Apple grants
	  only by special request. Enable "Time Sensitive Notifications" under
	  Signing & Capabilities in Xcode so this matches the provisioning profile.
	-->
	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>
	<!--
	  HealthKit (write-only sleep mirroring). Enable the "HealthKit" capability
	  under Signing & Capabilities in Xcode so this matches the provisioning
	  profile; leave "Clinical Health Records" off (not used). Madoromi requests
	  only share/write access for sleep analysis — never read access.
	-->
	<key>com.apple.developer.healthkit</key>
	<true/>
</dict>
</plist>
